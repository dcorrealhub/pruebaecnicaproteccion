# ---------------------------------------------------------------------------
# Maven Start Up Batch script
# ---------------------------------------------------------------------------

MAVEN_OPTS="$MAVEN_OPTS -Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR"

# resolve program directory
PRG="$0"
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
done
MAVEN_PROJECTBASEDIR=$(dirname "$PRG")

if [ -z "$MAVEN_SKIP_RC" ]; then
  if [ -f /etc/mavenrc ]; then
    . /etc/mavenrc
  fi
  if [ -f "$HOME/.mavenrc" ]; then
    . "$HOME/.mavenrc"
  fi
fi

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
case "$(uname -s)" in
  CYGWIN*|MINGW*)
    cygwin=true
    msys=true
    ;;
esac

# For Cygwin, ensure paths are not in Windows format before anything is done.
if $cygwin; then
  [ -n "$MAVEN_HOME" ] && [ -d "$MAVEN_HOME" ] || export MAVEN_HOME="$(cd "$PWD"/.. && pwd)"
  [ -n "$MAVEN_HOME" ] && [ -d "$MAVEN_HOME" ] && export MAVEN_HOME
fi

# Determine the Java command to use to start the JVM.
if [ -z "$JAVA_HOME" ]; then
  java_cmd="$(command -v java)"
else
  java_cmd="$JAVA_HOME/bin/java"
fi

# Check if Java exists.
if [ -z "$java_cmd" ]; then
  echo "Error: JAVA_HOME is not set and java could not be found in PATH." >&2
  exit 1
fi

# Retrieve the Maven distribution wrapper jar if not present.
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  echo "Wrapper jar not found at $MAVEN_WRAPPER_JAR." >&2
  exit 1
fi

exec "$java_cmd" \
  $MAVEN_OPTS \
  -classpath "$MAVEN_WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
