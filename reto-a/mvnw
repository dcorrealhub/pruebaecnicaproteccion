# See the NOTICE file at https://www.apache.org/licenses/LICENSE-2.0

if [ -z "$MAVEN_SKIP_RC" ]; then
  if [ -f /etc/mavenrc ]; then
    . /etc/mavenrc
  fi
  if [ -f "$HOME/.mavenrc" ]; then
    . "$HOME/.mavenrc"
  fi
fi

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
case "$(uname -s)" in
  CYGWIN*|MINGW*)
    cygwin=true
    msys=true
    ;;
esac

# For Cygwin, ensure paths are not in Windows format before anything is done.
if $cygwin; then
  [ -n "$MAVEN_HOME" ] && [ -d "$MAVEN_HOME" ] || export MAVEN_HOME="$(cd "$PWD"/.. && pwd)"
  [ -n "$MAVEN_HOME" ] && [ -d "$MAVEN_HOME" ] && export MAVEN_HOME
  ;;
fi

# Determine the Java command to use to start the JVM.
if [ -z "$JAVA_HOME" ]; then
  java_cmd="$(command -v java)"
else
  java_cmd="$JAVA_HOME/bin/java"
fi

# Check if Java exists.
if [ -z "$java_cmd" ]; then
  echo "Error: JAVA_HOME is not set and java could not be found in PATH." >&2
  exit 1
fi

# Retrieve the Maven distribution wrapper jar if not present.
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  if [ ! -f "$MAVEN_HOME/.mvn/wrapper/maven-wrapper.jar" ]; then
    if [ -f "$PWD/.mvn/wrapper/maven-wrapper.jar" ]; then
      MAVEN_WRAPPER_JAR="$PWD/.mvn/wrapper/maven-wrapper.jar"
    else
      echo "Wrapper jar not found. Please run 'mvn -N wrapper:wrapper' or download it manually." >&2
      exit 1
    fi
  else
    MAVEN_WRAPPER_JAR="$MAVEN_HOME/.mvn/wrapper/maven-wrapper.jar"
  fi
fi

if [ -z "$MAVEN_WRAPPER_JAR" ]; then
  echo "Wrapper jar not found." >&2
  exit 1
fi

exec "$java_cmd" -classpath "$MAVEN_WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
